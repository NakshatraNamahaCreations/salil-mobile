<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config.

  base-config: cleartext HTTP is allowed.
    - We control what the app talks to (axios baseURL + Razorpay's WebView).
    - The Razorpay WebView needs to load the backend's callback_url, which
      points at http://192.168.x.x:5001 during development.
    - In production EXPO_PUBLIC_BACKEND_URL is https://api.saliljaveri.com,
      so no real cleartext traffic happens.

  Play Store accepts this configuration; it surfaces a soft "uses cleartext"
  notice in the listing but does not reject the app. When you no longer need
  to test against a local HTTP backend, flip cleartextTrafficPermitted to
  "false" and add per-domain overrides for the specific LAN IPs you use.
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
